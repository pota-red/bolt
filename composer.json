{
  "name": "pota/bolt",
  "description": "Basic framework for GCP Cloud Run instances",
  "authors": [
    {
      "name": "James Linden (VE3JLN/N6NRD)",
      "email": "rfingaround@gmail.com",
      "role": "Developer"
    },
    {
